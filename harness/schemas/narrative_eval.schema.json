{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-heroes.co/schemas/cfo-round/narrative-eval.schema.json",
  "title": "CFO Narrative Evaluation",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "hard_status",
    "claims",
    "evaluator"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "hard_status": {
      "$ref": "#/$defs/hard_status"
    },
    "status_reason": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "claim_text",
          "status"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "claim_text": {
            "type": "string"
          },
          "supporting_number_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "$ref": "#/$defs/hard_status"
          },
          "issue": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "audience_fit": {
      "type": "object"
    },
    "evaluator": {
      "type": "object",
      "required": [
        "name",
        "signed_off"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "signed_off": {
          "type": "boolean"
        },
        "signed_at": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "hard_status": {
      "type": "string",
      "enum": [
        "PASS",
        "REVISE",
        "BLOCKED"
      ]
    }
  },
  "additionalProperties": true
}
